CompileFlags:
    CompilationDatabase: .zig-cache
    Add:
        [
            -Wno-gnu-statement-expression,
            -Wno-gnu-statement-expression-from-macro-expansion,
        ]

Diagnostics:
    Suppress: [static_non_static]
    MissingIncludes: Strict

Style:
    QuotedHeaders: ["lib/.*", "tests/.*", "fuzz/.*"]
    AngledHeaders: ["stdx/.*", "fmt/.*", "spdlog/.*", "magic_enum/.*", "gsl/.*"]
